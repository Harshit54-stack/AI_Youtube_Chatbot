# ─────────────────────────────────────────────────────────────────────────────
# YouTube RAG Chatbot — Backend Environment Variables
#
# Copy this file to backend/.env and fill in your values.
# .env is gitignored — NEVER commit real secrets.
#
# Quick start:
#   1. cp backend/.env.example backend/.env
#   2. Set GOOGLE_API_KEY (get free key at https://aistudio.google.com/app/apikey)
#   3. python run.py
# ─────────────────────────────────────────────────────────────────────────────

# ── Google Gemini API ─────────────────────────────────────────────────────────
# REQUIRED — get your free API key at https://aistudio.google.com/app/apikey
# Navigate to: Google AI Studio → Get API key → Create API key
GOOGLE_API_KEY=your_google_api_key_here

# ── LLM Model Configuration ───────────────────────────────────────────────────
# Choose a Gemini model:
#
#   gemini-2.5-flash    — Best balance of speed & quality  ← RECOMMENDED DEFAULT
#   gemini-2.5-pro      — Highest quality, complex reasoning
#   gemini-2.0-flash    — Fast, efficient, multimodal
#   gemini-2.0-flash-lite — Lightest 2.0 model
#   gemini-1.5-flash    — Stable, 1M token context window
#   gemini-1.5-pro      — Stable pro, 2M token context window
#
LLM_MODEL_NAME=gemini-2.5-flash
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=1024
LLM_TIMEOUT=60
LLM_MAX_RETRIES=2

# ── Embedding Model ───────────────────────────────────────────────────────────
# Google Generative AI embeddings — uses the same GOOGLE_API_KEY.
# Changing this invalidates all cached vector stores.
EMBEDDING_MODEL_NAME=models/gemini-embedding-2

# ── RAG Pipeline ─────────────────────────────────────────────────────────────
# CHUNK_SIZE    — max characters per transcript chunk (affects context quality)
# CHUNK_OVERLAP — characters of overlap between adjacent chunks (reduces gaps)
# RETRIEVER_K   — how many chunks to retrieve per question
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
RETRIEVER_K=4

# ── Vector Store Cache ────────────────────────────────────────────────────────
# Max number of video FAISS indexes to keep in RAM.
# Each index is ~10–50 MB depending on video length.
VECTOR_STORE_CACHE_SIZE=20

# ── API Server ────────────────────────────────────────────────────────────────
# Comma-separated list of allowed CORS origins for the React frontend.
# Development: http://localhost:3000 (CRA) or http://localhost:5173 (Vite)
# Production:  add your deployed frontend URL here
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ── Logging ───────────────────────────────────────────────────────────────────
# DEBUG | INFO | WARNING | ERROR | CRITICAL
# Use DEBUG for local development, INFO for production.
LOG_LEVEL=INFO

# ── Deployment Environment ────────────────────────────────────────────────────
# development | staging | production
# Controls certain startup log verbosity (future: feature flags)
APP_ENV=development
